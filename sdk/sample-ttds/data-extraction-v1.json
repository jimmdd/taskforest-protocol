{
  "ttd_id": "data-extraction-v1",
  "name": "Data Extraction",
  "version": "1.0",
  "description": "Extract structured data from unstructured sources (web pages, PDFs, documents).",
  "input": {
    "source_url": { "type": "url", "required": false, "description": "URL to scrape/extract from" },
    "source_text": { "type": "string", "required": false, "max_length": 200000, "description": "Raw text to extract from" },
    "schema": { "type": "json", "required": true, "description": "JSON schema defining what fields to extract" },
    "instructions": { "type": "string", "required": false, "description": "Natural language extraction instructions" }
  },
  "output": {
    "data": { "type": "json", "required": true, "description": "Extracted data matching the input schema" },
    "source_count": { "type": "integer", "required": false, "description": "Number of records extracted" },
    "completeness": { "type": "float", "min": 0, "max": 1, "description": "Fraction of schema fields successfully extracted" },
    "confidence": { "type": "float", "min": 0, "max": 1 }
  },
  "tools_required": ["llm", "web-scraper"],
  "estimated_compute": "medium",
  "verifiable_by": ["hash-match", "llm-judge"],
  "x-taskforest": {
    "privacy": "per"
  }
}
