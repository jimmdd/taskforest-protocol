{
  "private": true,
  "workspaces": [
    "sdk",
    "dark-forest"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "localnet:start": "anchor run light",
    "localnet:stop": "anchor run light-stop",
    "test:local:payments": "ANCHOR_PROVIDER_URL=http://127.0.0.1:8899 ANCHOR_WALLET=keys/taskforest.json npx ts-mocha -p ./tsconfig.json -t 1000000 tests/taskforest-payments.ts",
    "test:local:compress": "ANCHOR_PROVIDER_URL=http://127.0.0.1:8899 ANCHOR_WALLET=keys/taskforest.json npx ts-mocha -p ./tsconfig.json -t 120000 tests/compress-settlement.ts",
    "test:local": "./scripts/test-local.sh",
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@magicblock-labs/ephemeral-rollups-sdk": "^0.8.5",
    "@solana/web3.js": "^1.95.8"
  },
  "devDependencies": {
    "@lightprotocol/stateless.js": "^0.22.0",
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "bn.js": "^5.2.1",
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "prettier": "^2.6.2",
    "ts-mocha": "^10.0.0",
    "typescript": "^4.3.5"
  }
}
